{
  "name": "nfcryptobreak-v11",
  "version": "11.0.0",
  "description": "NFCryptoBreak v11.0 - Pocket Proxmark: Advanced NFC Security Research Tool",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "build:android:prod": "eas build --platform android --profile production",
    "prebuild": "expo prebuild --clean",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write src",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "react": "18.2.0",
    "react-native": "0.73.6",
    "expo": "^50.0.0",
    "expo-dev-client": "^3.0.0",
    "expo-file-system": "^16.0.0",
    "expo-secure-store": "^12.8.0",
    "expo-haptics": "^12.8.0",
    "@react-native-async-storage/async-storage": "^1.21.0",
    "react-native-nfc-manager": "^3.14.9",
    "crypto-js": "^4.1.1",
    "uuid": "^9.0.1",
    "@react-navigation/native": "^6.1.0",
    "@react-navigation/bottom-tabs": "^6.5.0",
    "react-native-screens": "^3.28.0",
    "react-native-safe-area-context": "^4.7.0",
    "react-native-gesture-handler": "^2.14.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "@types/crypto-js": "^4.1.1",
    "typescript": "^5.3.3",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "prettier": "^3.1.0",
    "@testing-library/react-native": "^12.4.0",
    "jest": "^29.7.0",
    "@babel/preset-typescript": "^7.23.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "keywords": [
    "nfc",
    "security",
    "cryptography",
    "android",
    "react-native",
    "proxmark",
    "mifare",
    "aes",
    "encryption"
  ],
  "author": "NFCryptoBreak Team",
  "license": "MIT"
}
